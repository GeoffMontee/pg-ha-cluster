# PgCat configuration for PostgreSQL HA Cluster
# Generated by Ansible - DO NOT EDIT MANUALLY

[general]
host = "{{ pgcat_listen_address }}"
port = {{ pgcat_port }}
enable_prometheus_exporter = true
prometheus_exporter_port = {{ pgcat_admin_port }}
admin_username = "{{ pgcat_admin_user }}"
admin_password = "{{ proxy_admin_password }}"

[pools.postgres]
pool_mode = "{{ pgcat_pool_mode }}"
default_role = "primary"
query_parser_enabled = true

[pools.postgres.users.0]
username = "postgres"
password = "{{ postgres_password }}"
pool_size = 50

[pools.postgres.shards.0]
database = "{{ pgcat_database }}"
servers = [
  ["{{ pg_primary_ip }}", 5432, "primary"],
{% for ip in pg_standby_ips %}
  ["{{ ip }}", 5432, "replica"]{% if not loop.last %},{% endif %}
{% endfor %}
]
