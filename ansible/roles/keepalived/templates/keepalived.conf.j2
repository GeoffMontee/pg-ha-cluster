# keepalived VRRP configuration for proxy HA
# Generated by Ansible - DO NOT EDIT MANUALLY

global_defs {
    router_id {{ inventory_hostname }}
    enable_script_security
}

vrrp_instance pg_proxy_vip {
    state BACKUP
    interface {{ keepalived_selected_interface }}
    virtual_router_id {{ keepalived_router_id }}
    priority {{ vrrp_priority | default(100) }}
    advert_int {{ keepalived_advert_interval }}

    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }

    unicast_peer {
{% for host in groups['proxy'] if host != inventory_hostname %}
        {{ hostvars[host].private_ip }}
{% endfor %}
    }

    virtual_ipaddress {
        {{ keepalived_virtual_ip }}
    }
}
