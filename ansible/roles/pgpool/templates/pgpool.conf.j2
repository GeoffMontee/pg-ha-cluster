# pgpool-II configuration for PostgreSQL HA Cluster
# Generated by Ansible - DO NOT EDIT MANUALLY

listen_addresses = '{{ pgpool_listen_addresses }}'
port = {{ pgpool_port }}
socket_dir = '/var/run/postgresql'
pcp_listen_addresses = '{{ pgpool_listen_addresses }}'
pcp_port = {{ pgpool_pcp_port }}
pcp_socket_dir = '/var/run/postgresql'

backend_hostname0 = '{{ pg_primary_ip }}'
backend_port0 = 5432
backend_weight0 = 1
backend_data_directory0 = '{{ postgresql_data_dir }}'
backend_flag0 = 'ALWAYS_PRIMARY|DISALLOW_TO_FAILOVER'
backend_application_name0 = 'pg-primary'
{% for ip in pg_standby_ips %}
backend_hostname{{ loop.index }} = '{{ ip }}'
backend_port{{ loop.index }} = 5432
backend_weight{{ loop.index }} = 1
backend_data_directory{{ loop.index }} = '{{ postgresql_data_dir }}'
backend_flag{{ loop.index }} = 'DISALLOW_TO_FAILOVER'
backend_application_name{{ loop.index }} = 'pg-standby-{{ loop.index }}'
{% endfor %}

enable_pool_hba = on
pool_passwd = ''
authentication_timeout = 60
allow_clear_text_frontend_auth = on

load_balance_mode = on
master_slave_mode = on
master_slave_sub_mode = 'stream'
sr_check_period = 10
sr_check_user = 'postgres'
sr_check_password = '{{ postgres_password }}'
health_check_period = {{ pgpool_health_check_period }}
health_check_timeout = {{ pgpool_health_check_timeout }}
health_check_user = 'postgres'
health_check_password = '{{ postgres_password }}'
health_check_max_retries = {{ pgpool_health_check_max_retries }}

log_destination = 'stderr'
logging_collector = on
log_directory = '/var/log/pgpool2'
log_filename = 'pgpool.log'
pid_file_name = '/var/run/postgresql/pgpool.pid'
