# ProxySQL configuration for PostgreSQL HA Cluster
# Generated by Ansible - DO NOT EDIT MANUALLY

datadir="/var/lib/proxysql"

admin_variables =
{
    admin_credentials="{{ proxysql_admin_user }}:{{ proxy_admin_password }}"
    mysql_ifaces="0.0.0.0:{{ proxysql_admin_port }}"
}

pgsql_variables =
{
    interfaces="0.0.0.0:{{ proxysql_pg_port }}"
    threads=4
    max_connections=4096
    default_query_timeout=36000000
    monitor_username="postgres"
    monitor_password="{{ postgres_password }}"
}

pgsql_servers =
(
    { address="{{ pg_primary_ip }}", port=5432, hostgroup={{ proxysql_primary_hostgroup }}, max_connections=1000 },
{% for ip in pg_standby_ips %}
    { address="{{ ip }}", port=5432, hostgroup={{ proxysql_replica_hostgroup }}, max_connections=1000 }{% if not loop.last %},{% endif %}
{% endfor %}
)

pgsql_users =
(
    { username="postgres", password="{{ postgres_password }}", default_hostgroup={{ proxysql_primary_hostgroup }}, transaction_persistent=1 }
)

pgsql_query_rules =
(
    { rule_id=1, active=1, match_pattern="^\\s*SELECT", destination_hostgroup={{ proxysql_replica_hostgroup }}, apply=1 },
    { rule_id=2, active=1, match_pattern=".*", destination_hostgroup={{ proxysql_primary_hostgroup }}, apply=1 }
)
